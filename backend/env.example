# Chaturanga Platform Configuration
# Copy to backend/.env and adjust as needed

APP_NAME="Chaturanga Chess Platform"
APP_VERSION="2.0.0"
DEBUG=true

HOST="0.0.0.0"
PORT=8000

# MySQL (localhost for local dev; docker-compose overrides host to `db`)
DATABASE_URL="mysql+pymysql://chaturanga:chaturanga@localhost:3306/chaturanga?charset=utf8mb4"

# External JWT (may rotate) — old tokens still accepted during rotation window
JWT_SECRET_KEY="change-me-in-production-use-a-long-random-string"
JWT_SECRET_KEY_PREVIOUS=

# Internal JWT — used to sign all app session tokens (keep stable)
INTERNAL_JWT="change-me-in-production-use-a-different-long-string"
INTERNAL_JWT_PREVIOUS=

JWT_KEY_ID="v1"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=604800
JWT_BLACKLIST_ENABLED=True
JWT_BLACKLIST_TOKEN_CHECKS='["access", "refresh"]'

# Chess engine
DEFAULT_ANALYSIS_TIME=1.0
MAX_ANALYSIS_TIME=10.0

# CORS (JSON array)
CORS_ORIGINS='["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000","http://127.0.0.1:3001"]'

LOG_LEVEL="INFO"
